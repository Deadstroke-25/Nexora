# -----------------------------------------------------------------------------
# Nexora - Environment Variables Template
# 
# Rename this file to `.env.local` for local development, and fill in the values.
# DO NOT commit your actual `.env.local` or `.env` files to git.
# -----------------------------------------------------------------------------

# --- Convex Backend Setup ---
# The deployment name (obtained from running `npx convex dev` or your Convex dashboard)
CONVEX_DEPLOYMENT=dev:your-deployment-name-123

# The public HTTP URL for the Convex server (e.g. https://your-app-123.convex.cloud)
NEXT_PUBLIC_CONVEX_URL=https://your-deployment-name-123.convex.cloud

# --- Clerk Authentication ---
# Clerk Publishable Key (from Clerk Dashboard > API Keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Clerk Secret Key (from Clerk Dashboard > API Keys)
CLERK_SECRET_KEY=sk_test_your_secret_key_here

# --- Liveblocks Collaboration ---
# Liveblocks Secret Key (from Liveblocks Dashboard > Projects > API Keys)
LIVEBLOCKS_SECRET_KEY=sk_test_your_liveblocks_secret_key_here

# --- Convex JWT Authentication ---
# The Clerk JWT issuer URL. This is the domain of your Clerk application frontend API
# Used by Convex to validate JWT tokens. (e.g. https://your-clerk-app.clerk.accounts.dev)
CLERK_JWT_ISSUER_DOMAIN=https://your-clerk-app.clerk.accounts.dev

# --- Clerk Navigation Redirects ---
# Define internal or Clerk-hosted authentication pages and redirect landing routes
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
